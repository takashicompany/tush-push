PUSHOVER_APP_TOKEN=your_app_token_here
PUSHOVER_USER_KEY=your_user_key_here

# 通知のインスタンス単位の上書き（任意）。
# プロジェクト設定や default_enabled より優先される。
#   on  系 (on/1/true/yes/enable)  → 必ず通知
#   off 系 (off/0/false/no/disable) → 必ず黙る
# 例: このPCは基本OFFにしておき、通知させたいClaude Codeだけ TUSH_PUSH=on で起動する。
#   TUSH_PUSH=on claude
# 起動ラッパー（headlenss 等）から立てる用途を想定。
# TUSH_PUSH=on
